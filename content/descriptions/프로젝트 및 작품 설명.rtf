 \uc0\u45257 \u51109 \u44256 \u45716  \u50864 \u47532 \u51032  \u51068 \u49345 \u50640  \u50612 \u46356 \u50640 \u46304  \u51316 \u51116 \u54620 \u45796 . \u51665 , \u49324 \u47924 \u49892 , \u49885 \u45817 , \u54200 \u51032 \u51216 , \u47560 \u53944 , \u48337 \u50896  \u46321 \u46321  \u50864 \u47532 \u44032  \u45257 \u51109 \u44256  \u47928 \u51012  \u50668 \u45716  \u44536  \u49692 \u44036  \u46496 \u45796 \u45768 \u45912  \u47676 \u51648  \u44057 \u51008  \u49884 \u44036 \u46308 \u51060  \u45257 \u51109 \u44256  \u49549 \u51004 \u47196  \u48744 \u47140  \u46308 \u50612 \u44032  \u49939 \u50668 \u51080 \u51648 \u45716  \u50506 \u51012 \u44620 . \u44208 \u44397  \u50864 \u47532 \u51032  \u49884 \u44036 \u51032  \u53960 \u51008  \u45257 \u51109 \u44256 \u50688 \u45912  \u44172  \u50500 \u45776 \u44620 . \
 \uc0\u44208 \u44397  \u49884 \u44036 \u51008  \u45257 \u51109 \u44256 (\u49884 \u44036 \u51032  \u53960 )\u50640  \u48744 \u47140  \u46308 \u50612 \u44032  \u50864 \u47532 \u51032  \u51068 \u49345 \u50640 \u49436  \u49324 \u46972 \u51256  \u51080 \u51012  \u44163 \u51060 \u45796 . \u51060 \u51228  \u45257 \u51109 \u44256  \u50504 \u51004 \u47196  \u46308 \u50612 \u44032  \u44256 \u50668  \u51080 \u45716  \u49884 \u44036 \u46308 \u51012  \u47560 \u51452 \u54616 \u44256 \u51088  \u54620 \u45796 .  \
\
 \uc0\u51060  \u51089 \u54408 \u51008  \u44288 \u44061 \u46308 \u51060  \u45257 \u51109 \u44256 (\u49884 \u44036 \u51032  \u53960 )\u51004 \u47196  \u46308 \u50612 \u44032  \u51088 \u49888 \u50640 \u44172 \u49436  \'91\u49324 \u46972 \u51652  \u49884 \u44036 \'92\u51012  \u49324 \u50976 \u54616 \u45716  \u51089 \u54408 \u51060  \u46112  \u44163  \u51060 \u45796 . \u44288 \u44061 \u46308 (\u49324 \u50976 \u54616 \u45716  \u51316 \u51116 \u46308 )\u51008  \u49352 \u47196 \u50868  \u49884 \u44036 \u51012  \u47560 \u51452 \u54616 \u45716  \u44163 \u51060  \u50500 \u45772  \u49324 \u46972 \u51664 \u51012  \u47785 \u44201 \u54616 \u44256 , \u44221 \u54744 \u54616 \u44256 , \u47560 \u51452 \u54616 \u47732 \u49436  \u51088 \u49888 \u51032  \u44256 \u50976 \u54620  \u49884 \u44036 \u51012  \u48156 \u44204 \u54616 \u44172  \u46112  \u44163 \u51060 \u44256  \u44536  \u46608 \u54620  \u49324 \u50976 \u54624  \u44163 \u51060 \u45796 . \u44033 \u51088 \u44032  \u49324 \u46972 \u51664 \u51012  \u53456 \u49353 \u54616 \u45716  \u44536  \u49884 \u44036  \u46041 \u50504 , \u47785 \u44201 , \u48156 \u44204 , \u44221 \u54744 \u51012  \u54616 \u45716  \u47672 \u47924 \u47492 \u51032  \u49884 \u44036 \u51060  \'91\u45208 \'92\u47484  \u49828 \u49828 \u47196  \u48148 \u46972 \u48372 \u45716  \u49884 \u44036 \u51004 \u47196  \u49692 \u54872 \u46108 \u45796 . \
\
 \uc0\u45257 \u51109 \u44256  \u50504 \u51004 \u47196  \u46308 \u50612 \u44036  \u44288 \u44061 \u46308 \u51008  \u46041 \u49884  \u45796 \u48156 \u51201 \u51004 \u47196  \u51316 \u51116 \u54616 \u45716  \u49939 \u50668 (\u44256 \u50668 ) \u51080 \u45716  \u49884 \u44036 \u46308 \u51012  \u54788 \u49892 \u44284  \u45796 \u47480  \u49884 \u44277 \u44036 \u51004 \u47196 \u49436  \'91\u47560 \u51452 \u52840 \'92\u51012  \u54624  \u44163  \u51060 \u47728 , \u51060  \u51089 \u54408 \u51008  \u44536  \u47560 \u51452 \u52824 \u45716  \u47588 \u44060 \u51060 \u51088  \u44536  \u49692 \u44036 \u51012  \u47564 \u46308 \u44256 \u51088  \u54620 \u45796 . \
